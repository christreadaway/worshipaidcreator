# Server
PORT=3000
NODE_ENV=production

# Session token signing secret — REQUIRED in production (set it in the
# Netlify environment variables). Tokens are HMAC signed; without this a
# public dev fallback secret is used (forgeable).
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

# Netlify Blobs (persistence on the hosted site).
# Normally wired automatically from the function request context. If
# /api/health reports persistence:"in-memory", set these explicitly
# (Site ID from Netlify site settings; a personal access token):
# NETLIFY_BLOBS_SITE_ID=
# NETLIFY_BLOBS_TOKEN=

# Google OAuth (optional — enables "Sign in with Google")
# Get credentials at https://console.cloud.google.com/apis/credentials
# 1. Create a project (or select existing)
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add your domain to Authorized JavaScript origins:
#    e.g., https://worshipaid.modernizecatholic.com
# 4. Copy the Client ID here
GOOGLE_CLIENT_ID=
